{
  "name": "@errand-ai/paperclip-adapter",
  "version": "0.1.12",
  "type": "module",
  "description": "Paperclip adapter for errand task execution engine",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "types": "./dist/server/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/vitest run",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/vitest"
  },
  "dependencies": {
    "@paperclipai/adapter-utils": "^2026.416.0",
    "@paperclipai/plugin-sdk": "^2026.416.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/errand-ai/paperclip-adapter.git"
  },
  "license": "MIT"
}
